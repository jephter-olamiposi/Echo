{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EchoSync",
  "version": "0.1.0",
  "identifier": "com.echosync.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EchoSync",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 700,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://echo-backend-bkbw.onrender.com wss://echo-backend-bkbw.onrender.com https://api.qrserver.com; img-src 'self' data: https://api.qrserver.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
